# Census API key — required for ACS and Building Permits Survey endpoints
# Get yours at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# URL to Zillow's publicly posted research data CSV
# Check https://www.zillow.com/research/data/ for the current download URL
ZILLOW_DATA_URL=https://files.zillowstatic.com/research/public_csvs/zhvi/example.csv
